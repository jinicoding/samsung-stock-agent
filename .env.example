# Evolution pipeline uses Claude Max subscription (claude CLI login).
# No ANTHROPIC_API_KEY needed — just run: claude login

# Required for data collection (KIS OpenAPI)
KIS_APP_KEY=...
KIS_APP_SECRET=...

# Required for Telegram reports
TELEGRAM_BOT_TOKEN=...

# Optional: GitHub Issues integration (gh CLI authentication)
# Create a token at https://github.com/settings/tokens with 'repo' scope
# Or run: gh auth login
GH_TOKEN=...
